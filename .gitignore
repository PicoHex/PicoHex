## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Benchmark results
benchmarks/**/results/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
[Nn]upkg/
artifacts/

# Visual Studio
.vs/
.vscode/
.idea/
*.sln.iml
*.DotSettings.user

# Test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Benchmark Results
BenchmarkDotNet.Artifacts/
results/

# .NET Core
project.lock.json
project.fragment.lock.json
**/Properties/launchSettings.json

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# Coverage
coverage*.json
coverage*.xml
coverage*.info
coverage/
coverage-report/

# Sisyphus
.sisyphus/

# Superpowers docs (discussion artifacts, not project docs)
docs/superpowers/

# OpenCode
.opencode/
.continue/

# OS files
.DS_Store
Thumbs.db
