<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <RootNamespace>PicoLog.Tests</RootNamespace>
    <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="PicoDI" Condition="'$(UseProjectReferences)' != 'true'" />
    <ProjectReference
      Include="..\..\..\PicoDI\src\PicoDI\PicoDI.csproj"
      Condition="'$(UseProjectReferences)' == 'true'"
    />
    <ProjectReference
      Include="..\..\..\PicoDI\src\PicoDI.Gen\PicoDI.Gen.csproj"
      OutputItemType="Analyzer"
    />
    <PackageReference Include="TUnit" />
    <PackageReference Include="Microsoft.Testing.Extensions.HangDump" />
    <PackageReference Include="Microsoft.Testing.Extensions.CrashDump" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\PicoLog.Abs\PicoLog.Abs.csproj" />
    <ProjectReference Include="..\..\src\PicoLog\PicoLog.csproj" />
    <ProjectReference Include="..\..\src\PicoLog.DI\PicoLog.DI.csproj" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\PicoLog.Gen\PicoLog.Gen.csproj" />
    <ProjectReference
      Include="..\..\src\PicoLog.Gen\PicoLog.Gen.csproj"
      OutputItemType="Analyzer"
      ReferenceOutputAssembly="false"
    />
  </ItemGroup>
</Project>
