<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <PublishAot>true</PublishAot>
        <TrimMode>full</TrimMode>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
      <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
      <RootNamespace>PicoLog.Tests</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="PicoDI" Condition="'$(UseProjectReferences)' != 'true'" />
      <ProjectReference Include="..\..\..\PicoDI\src\PicoDI\PicoDI.csproj" Condition="'$(UseProjectReferences)' == 'true'" />
      <PackageReference Include="TUnit" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\src\PicoLog.Abs\PicoLog.Abs.csproj" />
      <ProjectReference Include="..\..\src\PicoLog\PicoLog.csproj" />
      <ProjectReference Include="..\..\src\PicoLog.DI\PicoLog.DI.csproj" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\..\src\PicoLog.Gen\PicoLog.Gen.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    </ItemGroup>

</Project>
