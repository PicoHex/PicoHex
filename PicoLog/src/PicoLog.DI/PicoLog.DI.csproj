<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>true</IsPackable>
    <PackageId>PicoLog.DI</PackageId>
    <Description>PicoDI integration for PicoLog registration (AddPicoLog, WriteTo, ReadFrom).</Description>
    <PackageTags>PicoHex;Logging;AOT</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
    <ProjectReference Include="..\PicoLog\PicoLog.csproj" PrivateAssets="Build" />
    <ProjectReference
      Include="..\..\..\PicoDI\src\PicoDI.Abs\PicoDI.Abs.csproj"
      PrivateAssets="Build"
    />
    <ProjectReference
      Include="..\..\..\PicoDI\src\PicoDI.Gen\PicoDI.Gen.csproj"
      OutputItemType="Analyzer"
    />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
    <PackageReference Include="PicoLog" PrivateAssets="Build" />
    <PackageReference Include="PicoDI.Abs" PrivateAssets="Build" />
  </ItemGroup>

  <!-- PicoDI.Gen analyzer is required for cross-assembly open generic materialization
       of ILogger<T> → Logger<T>. Only PicoLog.DI needs this because it's the only DI
       package that registers open generics (PicoCfg.DI and PicoMediator.DI do not). -->

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>
</Project>
