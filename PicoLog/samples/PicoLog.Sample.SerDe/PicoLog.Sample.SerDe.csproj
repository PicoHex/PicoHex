<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AotOptimizationLevel>aggressive</AotOptimizationLevel>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
    <ProjectReference Include="..\..\src\PicoLog.Json\PicoLog.Json.csproj" />
    <ProjectReference Include="..\..\src\PicoLog\PicoLog.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
    <PackageReference Include="PicoLog" Version="$(Version)" />
    <PackageReference Include="PicoLog.Json" Version="$(Version)" />
  </ItemGroup>
</Project>
