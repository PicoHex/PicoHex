<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <IsPackable>true</IsPackable>
        <PackageId>PicoDI.Aop</PackageId>
        <Description>Source-generated AOP interception for PicoDI.</Description>
        <PackageTags>PicoHex;DI;IoC;AOT;AOP;Interception</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
        <ProjectReference Include="..\PicoDI.Abs\PicoDI.Abs.csproj">
            <ReferenceOutputAssembly>true</ReferenceOutputAssembly>
            <Private>false</Private>
        </ProjectReference>
        <ProjectReference Include="..\PicoDI\PicoDI.csproj">
            <ReferenceOutputAssembly>true</ReferenceOutputAssembly>
            <Private>false</Private>
        </ProjectReference>
    </ItemGroup>

    <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
        <PackageReference Include="PicoDI.Abs" />
        <PackageReference Include="PicoDI" />
    </ItemGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="PicoDI.Aop.Tests" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
    </ItemGroup>

</Project>
