<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AotOptimizationLevel>aggressive</AotOptimizationLevel>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\PicoMediator\PicoMediator.csproj" />
    <ProjectReference Include="..\..\src\PicoMediator.DI\PicoMediator.DI.csproj" />
    <ProjectReference Include="..\..\..\PicoDI\src\PicoDI\PicoDI.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
    <ProjectReference
      Include="..\..\src\PicoMediator.Gen\PicoMediator.Gen.csproj"
      OutputItemType="Analyzer"
      ReferenceOutputAssembly="false"
    />
  </ItemGroup>
</Project>
