<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>true</IsPackable>
    <PackageId>PicoCfg</PackageId>
    <Description>Async-first configuration providers and extensions for PicoCfg.</Description>
    <PackageTags>PicoHex;Configuration;AOT</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
    <ProjectReference Include="..\PicoCfg.Abs\PicoCfg.Abs.csproj">
      <ReferenceOutputAssembly>true</ReferenceOutputAssembly>
      <Private>false</Private>
    </ProjectReference>
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
    <PackageReference Include="PicoCfg.Abs" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="PicoCfg.Tests" />
    <InternalsVisibleTo Include="PicoCfg.DI.Tests" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" Visible="false" />
  </ItemGroup>
</Project>
