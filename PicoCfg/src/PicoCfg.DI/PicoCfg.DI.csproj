<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <IsPackable>true</IsPackable>
        <PackageId>PicoCfg.DI</PackageId>
        <Description>PicoDI registration helpers for PicoCfg roots, snapshots, and generated bound POCOs.</Description>
        <PackageTags>PicoHex;Configuration;AOT;SourceGenerator</PackageTags>
        <PackageReadmeFile>README.md</PackageReadmeFile>
    </PropertyGroup>

    <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
        <ProjectReference Include="..\PicoCfg\PicoCfg.csproj">
            <ReferenceOutputAssembly>true</ReferenceOutputAssembly>
            <Private>false</Private>
        </ProjectReference>
        <ProjectReference Include="..\PicoCfg.Gen\PicoCfg.Gen.csproj"
                          OutputItemType="Analyzer"
                          ReferenceOutputAssembly="false" />
    </ItemGroup>

    <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
        <PackageReference Include="PicoCfg" Version="$(Version)" />
        <PackageReference Include="PicoCfg.Gen" Version="$(Version)" />
    </ItemGroup>

    <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
        <ProjectReference Include="..\..\..\PicoDI\src\PicoDI\PicoDI.csproj" />
    </ItemGroup>

    <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
        <PackageReference Include="PicoDI" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\README.md" Pack="true" PackagePath="\" Link="README.md" />
    </ItemGroup>

</Project>
