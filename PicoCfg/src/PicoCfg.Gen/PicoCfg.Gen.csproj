<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <IsPackable>true</IsPackable>
        <PackageId>PicoCfg.Gen</PackageId>
        <Description>Source generator package for PicoCfg generated binding.</Description>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageReleaseNotes>Initial PicoCfg.Gen release with source-generated binding for PicoCfg and bundled runtime helpers.</PackageReleaseNotes>
        <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
        <IncludeBuildOutput>false</IncludeBuildOutput>
        <NoPackageAnalysis>true</NoPackageAnalysis>
        <GenerateDependencyFile>false</GenerateDependencyFile>
        <AssemblyName>PicoCfg.Gen</AssemblyName>
        <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_IncludeAnalyzerBuildOutput</TargetsForTfmSpecificContentInPackage>
    
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" />
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
        <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" />
    </ItemGroup>

    <ItemGroup>
        <AdditionalFiles Include="AnalyzerReleases.Shipped.md" />
        <AdditionalFiles Include="AnalyzerReleases.Unshipped.md" />
        <None Include="..\..\README.md" Pack="true" PackagePath="\" Link="README.md" />
    </ItemGroup>

    <Target Name="_IncludeAnalyzerBuildOutput">
        <ItemGroup>
            <TfmSpecificPackageFile Include="$(TargetPath)">
                <PackagePath>analyzers/dotnet/cs</PackagePath>
            </TfmSpecificPackageFile>
            <TfmSpecificPackageFile Include="..\PicoCfg\bin\$(Configuration)\net10.0\PicoCfg.dll">
                <PackagePath>lib/net10.0</PackagePath>
            </TfmSpecificPackageFile>
            <TfmSpecificPackageFile Include="..\PicoCfg.Abs\bin\$(Configuration)\netstandard2.0\PicoCfg.Abs.dll">
                <PackagePath>lib/net10.0</PackagePath>
            </TfmSpecificPackageFile>
        </ItemGroup>
    </Target>

</Project>
