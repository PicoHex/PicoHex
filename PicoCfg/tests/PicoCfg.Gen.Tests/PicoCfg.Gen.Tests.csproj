<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <Nullable>enable</Nullable>
        <ImplicitUsings>enable</ImplicitUsings>
        <IsPackable>false</IsPackable>
        <OutputType>Exe</OutputType>
        <PublishAot>true</PublishAot>
        <TrimMode>full</TrimMode>
        <!-- Allow PCFGGEN003 for partial binding test types -->
        <NoWarn>$(NoWarn);PCFGGEN003</NoWarn>
        <TestingPlatformDotnetTestSupport>true</TestingPlatformDotnetTestSupport>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="TUnit" />
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
        <PackageReference Include="PicoDI" Condition="'$(UseProjectReferences)' != 'true'" />
        <ProjectReference Include="..\..\..\PicoDI\src\PicoDI\PicoDI.csproj" Condition="'$(UseProjectReferences)' == 'true'" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\PicoCfg\PicoCfg.csproj" />
        <ProjectReference Include="..\..\src\PicoCfg.DI\PicoCfg.DI.csproj" />
        <ProjectReference Include="..\..\src\PicoCfg.Gen\PicoCfg.Gen.csproj" />
        <ProjectReference Include="..\..\src\PicoCfg.Gen\PicoCfg.Gen.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    </ItemGroup>

</Project>
